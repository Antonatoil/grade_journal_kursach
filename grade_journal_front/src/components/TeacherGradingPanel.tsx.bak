import { useEffect, useMemo, useState } from 'react';
import { useMutation, useQuery } from '@tanstack/react-query';
import { api } from '../lib/api';

type Props = {
  title: string;
  description: string;
};

type GroupOption = {
  groupId: number;
  groupCode: string;
  courseNo: number;
};

type LessonOption = {
  scheduleId: number;
  lessonDate: string;
  timeSlot: string;
  courseName: string;
  groupCode: string;
  topic: string;
};

type GradeRow = {
  studentId: number;
  enrollmentId: number;
  fullName: string;
  studentCard: string;
  present: boolean;
  missedHours: number;
  gradeValue: string;
  teacherComment: string;
};

function unwrapArray(value: any): any[] {
  if (Array.isArray(value)) return value;
  if (Array.isArray(value?.items)) return value.items;
  if (Array.isArray(value?.content)) return value.content;
  if (Array.isArray(value?.data)) return value.data;
  return [];
}

function normalizeGroups(raw: any): GroupOption[] {
  return unwrapArray(raw)
    .map((item: any) => ({
      groupId: Number(item.groupId ?? 0),
      groupCode: String(item.groupCode ?? ''),
      courseNo: Number(item.courseNo ?? 0)
    }))
    .filter((item: GroupOption) => item.groupId > 0 && item.groupCode.trim().length > 0)
    .sort((a: GroupOption, b: GroupOption) => a.groupCode.localeCompare(b.groupCode, 'ru'));
}

function normalizeLessons(raw: any): LessonOption[] {
  return unwrapArray(raw)
    .map((item: any) => ({
      scheduleId: Number(item.scheduleId ?? 0),
      lessonDate: String(item.lessonDate ?? ''),
      timeSlot: String(item.timeSlot ?? ''),
      courseName: String(item.courseName ?? ''),
      groupCode: String(item.groupCode ?? ''),
      topic: String(item.topic ?? '')
    }))
    .filter((item: LessonOption) => item.scheduleId > 0)
    .sort((a: LessonOption, b: LessonOption) => {
      const da = new Date(a.lessonDate).getTime();
      const db = new Date(b.lessonDate).getTime();
      if (da !== db) return da - db;
      return a.timeSlot.localeCompare(b.timeSlot, 'ru');
    });
}

function normalizeRows(raw: any): GradeRow[] {
  return unwrapArray(raw)
    .map((item: any) => ({
      studentId: Number(item.studentId ?? 0),
      enrollmentId: Number(item.enrollmentId ?? 0),
      fullName: String(item.fullName ?? ''),
      studentCard: String(item.studentCard ?? ''),
      present: Boolean(item.present ?? false),
      missedHours: Number(item.missedHours ?? 0),
      gradeValue:
        item.gradeValue === null || item.gradeValue === undefined
          ? ''
          : String(Math.round(Number(item.gradeValue))),
      teacherComment: String(item.teacherComment ?? '')
    }))
    .filter((item: GradeRow) => item.studentId > 0 && item.enrollmentId > 0 && item.fullName.trim().length > 0)
    .sort((a: GradeRow, b: GradeRow) => a.fullName.localeCompare(b.fullName, 'ru'));
}

function formatDate(value: string) {
  if (!value) return '—';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString('ru-RU');
}

function clampGrade(value: string) {
  if (value.trim() === '') return '';

  const numeric = Number(value.replace(',', '.'));
  if (Number.isNaN(numeric)) return '';

  return String(Math.max(0, Math.min(10, Math.round(numeric))));
}

function extractErrorMessage(error: any) {
  return (
    error?.response?.data?.message ||
    error?.response?.data?.error ||
    error?.message ||
    'Не удалось выполнить запрос.'
  );
}

export function TeacherGradingPanel({ title, description }: Props) {
  const [selectedGroupId, setSelectedGroupId] = useState('');
  const [selectedLessonId, setSelectedLessonId] = useState('');
  const [rows, setRows] = useState<GradeRow[]>([]);
  const [message, setMessage] = useState<string | null>(null);

  const groupsQuery = useQuery({
    queryKey: ['teacher-grading', 'groups'],
    queryFn: async () => {
      const response = await api.get('/api/teacher-grading/groups');
      return normalizeGroups(response.data);
    }
  });

  useEffect(() => {
    if (!selectedGroupId && groupsQuery.data?.length) {
      setSelectedGroupId(String(groupsQuery.data[0].groupId));
    }
  }, [selectedGroupId, groupsQuery.data]);

  useEffect(() => {
    setSelectedLessonId('');
    setRows([]);
    setMessage(null);
  }, [selectedGroupId]);

  const lessonsQuery = useQuery({
    enabled: Boolean(selectedGroupId),
    queryKey: ['teacher-grading', 'lessons', selectedGroupId],
    queryFn: async () => {
      const response = await api.get('/api/teacher-grading/lessons', {
        params: { groupId: Number(selectedGroupId) }
      });
      return normalizeLessons(response.data);
    }
  });

  useEffect(() => {
    if (lessonsQuery.data?.length) {
      const exists = lessonsQuery.data.some(
        (lesson) => String(lesson.scheduleId) === selectedLessonId
      );

      if (!selectedLessonId || !exists) {
        setSelectedLessonId(String(lessonsQuery.data[0].scheduleId));
      }
    } else {
      setSelectedLessonId('');
    }
  }, [selectedLessonId, lessonsQuery.data]);

  const rowsQuery = useQuery({
    enabled: Boolean(selectedLessonId),
    queryKey: ['teacher-grading', 'rows', selectedLessonId],
    queryFn: async () => {
      const response = await api.get('/api/teacher-grading/lesson-students', {
        params: { scheduleId: Number(selectedLessonId) }
      });
      return normalizeRows(response.data);
    }
  });

  useEffect(() => {
    setRows(rowsQuery.data ?? []);
  }, [rowsQuery.data]);

  const selectedLesson = useMemo(
    () => (lessonsQuery.data ?? []).find((lesson) => String(lesson.scheduleId) === selectedLessonId),
    [lessonsQuery.data, selectedLessonId]
  );

  const stats = useMemo(() => {
    return {
      total: rows.length,
      withGrades: rows.filter((row) => row.gradeValue !== '').length,
      absent: rows.filter((row) => !row.present).length
    };
  }, [rows]);

  const saveMutation = useMutation({
    mutationFn: async () => {
      const payload = {
        students: rows.map((row) => ({
          studentId: row.studentId,
          enrollmentId: row.enrollmentId,
          present: row.present,
          gradeValue: row.gradeValue.trim() === '' ? null : Number(clampGrade(row.gradeValue)),
          teacherComment: row.teacherComment.trim() === '' ? null : row.teacherComment.trim()
        }))
      };

      await api.post(
        `/api/teacher-grading/lesson-students/${Number(selectedLessonId)}/save`,
        payload
      );
    },
    onSuccess: async () => {
      await rowsQuery.refetch();
      const now = new Date().toLocaleTimeString('ru-RU');
      setMessage(`Сохранено успешно (${now}). Таблица перечитана из базы.`);
    },
    onError: (error: any) => {
      setMessage(extractErrorMessage(error));
    }
  });

  return (
    <section className="rounded-3xl border border-slate-300 bg-white p-6 shadow-sm">
      <div className="mb-5">
        <h2 className="text-2xl font-semibold text-slate-900">{title}</h2>
        <p className="mt-2 text-slate-600">{description}</p>
      </div>

      {message && (
        <div className="mb-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700">
          {message}
        </div>
      )}

      <div className="grid gap-4 xl:grid-cols-2">
        <label className="space-y-2">
          <span className="text-sm font-medium text-slate-700">Группа</span>
          <select
            value={selectedGroupId}
            onChange={(event) => setSelectedGroupId(event.target.value)}
            className="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-blue-500"
          >
            {!groupsQuery.data?.length && <option value="">Нет групп</option>}
            {(groupsQuery.data ?? []).map((group) => (
              <option key={group.groupId} value={group.groupId}>
                {group.groupCode} — курс {group.courseNo}
              </option>
            ))}
          </select>
        </label>

        <label className="space-y-2">
          <span className="text-sm font-medium text-slate-700">Пара</span>
          <select
            value={selectedLessonId}
            onChange={(event) => setSelectedLessonId(event.target.value)}
            className="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-blue-500"
          >
            {!lessonsQuery.data?.length && <option value="">Нет пар</option>}
            {(lessonsQuery.data ?? []).map((lesson) => (
              <option key={lesson.scheduleId} value={lesson.scheduleId}>
                {lesson.courseName} — {formatDate(lesson.lessonDate)} — {lesson.timeSlot}
              </option>
            ))}
          </select>
        </label>
      </div>

      {groupsQuery.isLoading && (
        <div className="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-600">
          Загрузка групп...
        </div>
      )}

      {groupsQuery.isError && (
        <div className="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-700">
          Не удалось загрузить список групп: {extractErrorMessage(groupsQuery.error)}
        </div>
      )}

      {lessonsQuery.isLoading && selectedGroupId && (
        <div className="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-600">
          Загрузка пар...
        </div>
      )}

      {lessonsQuery.isError && selectedGroupId && (
        <div className="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-700">
          Не удалось загрузить пары: {extractErrorMessage(lessonsQuery.error)}
        </div>
      )}

      {selectedLesson && (
        <div className="mt-6 grid gap-4 lg:grid-cols-4">
          <div className="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <div className="text-sm text-slate-500">Предмет</div>
            <div className="mt-1 font-semibold text-slate-900">{selectedLesson.courseName}</div>
          </div>

          <div className="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <div className="text-sm text-slate-500">Дата</div>
            <div className="mt-1 font-semibold text-slate-900">
              {formatDate(selectedLesson.lessonDate)}
            </div>
          </div>

          <div className="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <div className="text-sm text-slate-500">Время</div>
            <div className="mt-1 font-semibold text-slate-900">{selectedLesson.timeSlot || '—'}</div>
          </div>

          <div className="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <div className="text-sm text-slate-500">Тема</div>
            <div className="mt-1 font-semibold text-slate-900">{selectedLesson.topic || '—'}</div>
          </div>
        </div>
      )}

      {selectedLessonId && !rowsQuery.isLoading && !rowsQuery.isError && (
        <div className="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700">
          Найдено студентов: <b>{stats.total}</b>, с уже имеющейся оценкой: <b>{stats.withGrades}</b>, отсутствовали на выбранной паре: <b>{stats.absent}</b>.
        </div>
      )}

      {rowsQuery.isLoading && selectedLessonId && (
        <div className="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-600">
          Загрузка студентов по паре...
        </div>
      )}

      {rowsQuery.isError && selectedLessonId && (
        <div className="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-700">
          Не удалось загрузить студентов по выбранной паре: {extractErrorMessage(rowsQuery.error)}
        </div>
      )}

      <div className="mt-6 overflow-x-auto">
        <table className="min-w-full border-separate border-spacing-0 text-sm">
          <thead>
            <tr className="bg-slate-100 text-slate-700">
              <th className="rounded-l-2xl px-4 py-3 text-left font-semibold">Студент</th>
              <th className="px-4 py-3 text-left font-semibold">Студ. билет</th>
              <th className="px-4 py-3 text-left font-semibold">Присутствовал</th>
              <th className="px-4 py-3 text-left font-semibold">Пропущено часов</th>
              <th className="px-4 py-3 text-left font-semibold">Оценка</th>
              <th className="rounded-r-2xl px-4 py-3 text-left font-semibold">Комментарий</th>
            </tr>
          </thead>
          <tbody>
            {rows.length ? (
              rows.map((row, index) => (
                <tr key={`${row.studentId}-${row.enrollmentId}`} className="border-b border-slate-200">
                  <td className="px-4 py-3 text-slate-800">{row.fullName}</td>
                  <td className="px-4 py-3 text-slate-700">{row.studentCard || '—'}</td>
                  <td className="px-4 py-3">
                    <input
                      type="checkbox"
                      checked={row.present}
                      onChange={(event) =>
                        setRows((prev) =>
                          prev.map((item, currentIndex) =>
                            currentIndex === index
                              ? { ...item, present: event.target.checked }
                              : item
                          )
                        )
                      }
                      className="h-4 w-4"
                    />
                  </td>
                  <td className="px-4 py-3 text-slate-700">{row.missedHours}</td>
                  <td className="px-4 py-3">
                    <input
                      value={row.gradeValue}
                      onChange={(event) =>
                        setRows((prev) =>
                          prev.map((item, currentIndex) =>
                            currentIndex === index
                              ? { ...item, gradeValue: event.target.value }
                              : item
                          )
                        )
                      }
                      onBlur={(event) =>
                        setRows((prev) =>
                          prev.map((item, currentIndex) =>
                            currentIndex === index
                              ? { ...item, gradeValue: clampGrade(event.target.value) }
                              : item
                          )
                        )
                      }
                      placeholder="0-10"
                      className="w-24 rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none transition focus:border-blue-500"
                    />
                  </td>
                  <td className="px-4 py-3">
                    <input
                      value={row.teacherComment}
                      onChange={(event) =>
                        setRows((prev) =>
                          prev.map((item, currentIndex) =>
                            currentIndex === index
                              ? { ...item, teacherComment: event.target.value }
                              : item
                          )
                        )
                      }
                      placeholder="Комментарий"
                      className="w-full min-w-[220px] rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none transition focus:border-blue-500"
                    />
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colSpan={6} className="px-4 py-6 text-center text-slate-500">
                  Нет данных для отображения. Сначала выберите группу и пару.
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      <div className="mt-5 flex flex-wrap gap-3">
        <button
          onClick={() => {
            setMessage(null);
            saveMutation.mutate();
          }}
          disabled={!selectedLessonId || saveMutation.isPending || rows.length === 0}
          className="rounded-2xl bg-blue-600 px-4 py-3 font-medium text-white transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60"
        >
          {saveMutation.isPending ? 'Сохранение...' : 'Сохранить'}
        </button>

        <button
          onClick={() => {
            setMessage(null);
            rowsQuery.refetch();
          }}
          disabled={!selectedLessonId}
          className="rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 font-medium text-slate-700 transition hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Обновить
        </button>
      </div>
    </section>
  );
}
